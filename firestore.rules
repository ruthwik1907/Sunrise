rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }
    
    function isStaff() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role in ['admin', 'doctor', 'receptionist', 'pharmacist', 'lab_technician'];
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
        request.auth.token.email in ["admin@hospital.com", "220701237@rajalakshmi.edu.in"]
      );
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Default: Deny all, then allow specific
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Allow signup
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Every user should be able to trigger an audit log write via backend-like patterns
      allow update, delete: if false; // Audit logs should be immutable
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.patientId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isStaff() || (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /medicalRecords/{recordId} {
      allow read: if isAdmin() || hasRole('doctor') || (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow write: if isAdmin() || hasRole('doctor');
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow create: if isAdmin() || hasRole('doctor');
      allow update: if isAdmin() || hasRole('doctor') || hasRole('pharmacist');
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow write: if isAdmin() || hasRole('pharmacist') || hasRole('receptionist');
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasRole('pharmacist');
    }

    match /labRequests/{requestId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow write: if isAdmin() || hasRole('doctor') || hasRole('lab_technician');
    }

    match /labReports/{reportId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow write: if isAdmin() || hasRole('lab_technician');
    }

    match /beds/{bedId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasRole('receptionist');
    }

    match /equipment/{equipmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /bills/{billId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow write: if isAdmin() || hasRole('pharmacist');
    }

    match /adminInvoices/{invoiceId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || hasRole('pharmacist');
      allow update, delete: if isAdmin();
    }

    match /bedBookings/{bookingId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.patientId == request.auth.uid);
      allow write: if isAdmin() || hasRole('doctor') || hasRole('receptionist');
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.receiverId == request.auth.uid); // Mark read
      allow delete: if isAdmin();
    }
  }
}
